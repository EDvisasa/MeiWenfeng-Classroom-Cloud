# ----------------------------------------------------------------------
# 用户数据与私密配置 (User Data & Secrets - Do Not Commit)
# ----------------------------------------------------------------------
# 数据库（含用户聊天记录、好感度进度、系统配置等隐私数据）
backend/*.db
# 本地向量知识库（包含上传的讲义、个人文档和压缩的长期记忆）
backend/rag_index/
# 真实 API 密钥与环境变量（绝对不能提交）
.env
.env.*
!.env.example

# 屏蔽原版人设文档（只保留精简人设）
backend/services/mei_wenfeng_persona.txt

# ----------------------------------------------------------------------
# 缓存与运行日志 (Caches & Logs)
# ----------------------------------------------------------------------
*.log
logs/
.pytest_cache/
__pycache__/
*.pyc
*.pyo
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------
# 虚拟环境与依赖 (Environments & Dependencies)
# ----------------------------------------------------------------------
# Python 虚拟环境
.venv/
env/
venv/
# Node 依赖
frontend/node_modules/
vscode-extension/node_modules/

# ----------------------------------------------------------------------
# 构建产物 (Build Artifacts)
# ----------------------------------------------------------------------
# 前端构建产物
frontend/dist/
frontend/build/
# 插件构建产物
vscode-extension/out/
vscode-extension/dist/

# ----------------------------------------------------------------------
# 用户隐私与学习数据隔离 (Classroom Privacy & User Learning Data)
# ----------------------------------------------------------------------
# 课上产生的所有学习物料、理论讲义(References)、试错作业(Sandbox)、记录(LDRs)均保存在 data/materials/ 下
# 属个人私密学习资产，严禁提交或同步至云端（保留人设卡片等初始配置）
data/materials/**
!data/materials/
!data/materials/*/
!data/materials/*/README.md
