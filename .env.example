# ==========================================
# 媚吻锋随身课堂 - 环境变量配置模板
# ==========================================

# 1. 后端与服务端口配置
PORT=12701
NODE_PORT=12702
FRONTEND_PORT=12703

# 2. 在线大模型 API 配置 (默认走 OpenAI 兼容协议)
# 填写您的 OpenAI 兼容服务 API Key (或 DeepSeek/第三方中转 Key)
AIRP_MODEL_API_KEY=your_openai_compatible_api_key_here
AIRP_MODEL_BASE_URL=https://api.openai.com/v1
AIRP_MODEL_NAME=gpt-4o-mini

# 3. 本地 RAGFlow 知识库配置（可选项）
RAGFLOW_API_KEY=your_ragflow_api_key_here
RAGFLOW_BASE_URL=http://localhost/api/v1

# 4. 备用大模型配置 (供前端切换备用)
QWEN_LOCAL_URL=http://localhost:8080/v1
GEMMA_LOCAL_URL=http://localhost:11434/v1
CLAUDE_API_KEY=your_claude_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# 5. 本地路径配置 (可选，若不填则默认使用 data/ 目录)
# 挂载的本地角色图片目录
# IMAGE_DIR=D:/Path/To/Your/Images
# /update_persona 读取的原始人设卡目录
# PERSONA_SOURCE_DIR=D:/Path/To/Your/Persona/Source
# /update_persona 输出同步精简人设的外部目录
# PERSONA_SIMPLIFIED_OUTPUT_DIR=D:/Path/To/Your/Persona/Export
